# External port for the proxy (clients connect here)
#PUBLIC_PORT=1443

# External port for the web page with proxy link
#WEB_PORT=1444

# Generate secret with: openssl rand -hex 16
#SECRET=

# Domain for Fake TLS masking (leave empty to disable)
#FAKE_TLS_DOMAIN=

# Public address of the server (leave empty to auto-detect external IP)
#PUBLIC_ADDRESS=
