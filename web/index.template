<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>TG WS Proxy</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        body {
            background: #121212;
            color: #eee;
            font-family: 'Inter', system-ui, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            text-align: center;
        }
        .card {
            background: #1e1e1e;
            border: 1px solid #333;
            border-radius: 1.5rem;
            padding: 2.5rem;
            max-width: 480px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.7);
        }
        h1 { color: #4fe6d4; font-weight: 500; margin-bottom: 0.5rem; }
        p { color: #aaa; margin-bottom: 2rem; }
        .link-box {
            background: #0a0a0a;
            border: 1px solid #444;
            border-radius: 3rem;
            padding: 0.8rem 1.2rem;
            word-break: break-all;
            font-family: monospace;
            color: #8bc4ff;
            margin: 1.5rem 0;
            user-select: all;
        }
        .btn {
            display: inline-block;
            padding: 0.9rem 2rem;
            border: none;
            border-radius: 3rem;
            background: #2a8fff;
            color: white;
            font-size: 1.1rem;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: background 0.2s;
        }
        .btn:hover { background: #4da6ff; }
    </style>
</head>
<body>
    <div class="card">
        <h1>⚡ TG WS Proxy</h1>
        <p>Прокси работает в режиме Fake‑TLS.<br>Скопируйте ссылку или нажмите кнопку для подключения.</p>

        <div class="link-box" id="proxyLink"></div>
        <a class="btn" id="connectBtn" href="#">🔗 Подключить Telegram</a>
    </div>

    <script>
        // Собираем ссылку из переменных окружения, подставленных сервером
        const HOST = window.location.hostname;
        const PORT = '${PUBLIC_PORT}';
        const SECRET = '${SECRET}';
        const FAKE_TLS_DOMAIN = '${FAKE_TLS_DOMAIN}';

        function hex(str) {
            return Array.from(str).map(c => c.charCodeAt(0).toString(16)).join('');
        }
        const domainHex = hex(FAKE_TLS_DOMAIN);
        const fullSecret = 'ee' + SECRET + domainHex;

        const proxyUrl = `tg://proxy?server=${HOST}&port=${PORT}&secret=${fullSecret}`;

        document.getElementById('proxyLink').textContent = proxyUrl;
        document.getElementById('connectBtn').href = proxyUrl;
    </script>
</body>
</html>
