<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>TG WS Proxy</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        body {
            background: #121212;
            color: #eee;
            font-family: 'Inter', system-ui, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            text-align: center;
        }
        .card {
            background: #1e1e1e;
            border: 1px solid #333;
            border-radius: 1.5rem;
            padding: 2.5rem;
            max-width: 480px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.7);
        }
        h1 { color: #4fe6d4; font-weight: 500; margin-bottom: 0.5rem; }
        p { color: #aaa; margin-bottom: 2rem; }
        .link-box {
            background: #0a0a0a;
            border: 1px solid #444;
            border-radius: 3rem;
            padding: 0.8rem 1.2rem;
            word-break: break-all;
            font-family: monospace;
            color: #8bc4ff;
            margin: 1.5rem 0;
            user-select: all;
        }
        .btn {
            display: inline-block;
            padding: 0.9rem 2rem;
            border: none;
            border-radius: 3rem;
            background: #2a8fff;
            color: white;
            font-size: 1.1rem;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: background 0.2s;
        }
        .btn:hover { background: #4da6ff; }
        .lang-switch {
            margin-top: 1.5rem;
            display: flex;
            justify-content: center;
            gap: 1rem;
        }
        .lang-btn {
            background: #2a2a2a;
            border: 1px solid #444;
            color: #ccc;
            padding: 0.4rem 1rem;
            border-radius: 2rem;
            font-size: 0.9rem;
            cursor: pointer;
            transition: background 0.2s;
        }
        .lang-btn.active {
            background: #4fe6d4;
            color: #121212;
            border-color: #4fe6d4;
            font-weight: 600;
        }
        .lang-btn:hover {
            background: #3a3a3a;
        }
        .lang-btn.active:hover {
            background: #6bf0e2;
        }
    </style>
</head>
<body>
    <div class="card">
        <h1 id="title"></h1>
        <p id="description"></p>

        <div class="link-box" id="proxyLink"></div>
        <a class="btn" id="connectBtn" href="#">🔗 Connect</a>

        <div class="lang-switch">
            <button class="lang-btn" data-lang="ru">RU</button>
            <button class="lang-btn" data-lang="en">EN</button>
        </div>
    </div>

    <script>
        // ========== Переводы ==========
        const translations = {
            ru: {
                title: '⚡ TG WS Proxy',
                description: '<br>Скопируйте ссылку или нажмите кнопку для подключения.',
                connectBtn: '🔗 Подключить Telegram'
            },
            en: {
                title: '⚡ TG WS Proxy',
                description: '<br>Copy the link or click the button to connect.',
                connectBtn: '🔗 Connect Telegram'
            }
        };

        // ========== Определение языка ==========
        function getInitialLang() {
            // 1. Параметр URL ?lang=ru/en
            const urlParams = new URLSearchParams(window.location.search);
            const paramLang = urlParams.get('lang');
            if (paramLang && translations[paramLang]) return paramLang;

            // 2. Cookie lang
            const cookieMatch = document.cookie.match(/(?:^|;\s*)lang=([a-z]{2})/);
            if (cookieMatch && translations[cookieMatch[1]]) return cookieMatch[1];

            // 3. Язык браузера (первые два символа)
            const browserLang = navigator.language.slice(0, 2);
            if (translations[browserLang]) return browserLang;

            // 4. По умолчанию русский
            return 'ru';
        }

        let currentLang = getInitialLang();

        // ========== Смена языка ==========
        function setLang(lang) {
            if (!translations[lang]) return;
            currentLang = lang;

            // Сохраняем выбор в cookie на год
            document.cookie = `lang=${lang}; path=/; max-age=31536000; SameSite=Lax`;

            applyLanguage();
            updateActiveButton();
        }

        function applyLanguage() {
            const t = translations[currentLang];
            document.getElementById('title').textContent = t.title;
            document.getElementById('description').innerHTML = t.description;
            document.getElementById('connectBtn').textContent = t.connectBtn;
        }

        function updateActiveButton() {
            document.querySelectorAll('.lang-btn').forEach(btn => {
                const lang = btn.getAttribute('data-lang');
                if (lang === currentLang) {
                    btn.classList.add('active');
                } else {
                    btn.classList.remove('active');
                }
            });
        }

        // ========== Сборка прокси-ссылки (без изменений) ==========
        const HOST = window.location.hostname;
        const PORT = '${PUBLIC_PORT}';
        const SECRET = '${SECRET}';
        const FAKE_TLS_DOMAIN = '${FAKE_TLS_DOMAIN}';

        function hex(str) {
            return Array.from(str).map(c => c.charCodeAt(0).toString(16)).join('');
        }
        const domainHex = hex(FAKE_TLS_DOMAIN);
        const fullSecret = 'ee' + SECRET + domainHex;

        const proxyUrl = `tg://proxy?server=${HOST}&port=${PORT}&secret=${fullSecret}`;

        // Вставляем ссылку и настраиваем кнопку
        document.getElementById('proxyLink').textContent = proxyUrl;
        document.getElementById('connectBtn').href = proxyUrl;

        // ========== Инициализация интерфейса ==========
        applyLanguage();
        updateActiveButton();

        // Навешиваем обработчики на кнопки переключения языка
        document.querySelectorAll('.lang-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                const lang = this.getAttribute('data-lang');
                setLang(lang);
            });
        });
    </script>
</body>
</html>
